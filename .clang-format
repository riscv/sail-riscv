Language: Cpp
BasedOnStyle: WebKit
AlignArrayOfStructures: Left
AlignAfterOpenBracket: Align
AllowShortFunctionsOnASingleLine: Empty
ColumnLimit: 120
Cpp11BracedListStyle: true
IndentWidth: 2
PointerAlignment: Right
SortIncludes: Never
AlignTrailingComments: true
AccessModifierOffset: -2
InsertBraces: true
